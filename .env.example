# =============================================================================
# DAIL Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=DAIL
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://dail:dail_password@localhost:5432/dail_db
DATABASE_URL_SYNC=postgresql://dail:dail_password@localhost:5432/dail_db
POSTGRES_USER=dail
POSTGRES_PASSWORD=dail_password
POSTGRES_DB=dail_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# CourtListener API
COURTLISTENER_API_TOKEN=xyz
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_RATE_LIMIT=5000

# Sentry (optional)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
