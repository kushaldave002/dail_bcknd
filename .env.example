# =============================================================================
# DAIL Backend - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values.

# Application
APP_NAME=DAIL
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://dail-bcknd-jpurn9gas-kushaldave002s-projects.vercel.app

# PostgreSQL Database
DATABASE_URL=postgresql://postgres.ladusnubiywabtiuehaq:Dhwanil@2503@aws-0-us-west-2.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.ladusnubiywabtiuehaq:Dhwanil@2503@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# AI / LLM Keys  (OpenRouter — provides access to GPT-4o-mini & Gemini)
# Get your key at https://openrouter.ai/keys — never commit the real key
OPENROUTER_API_KEY=
# Legacy direct keys (optional, not used when OpenRouter is configured)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=INFO
